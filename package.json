{
  "name": "@four-bytes/four-opencode-context-curator",
  "version": "0.2.0",
  "description": "opencode-Plugin: kuratiert Context vor LLM-Request — statt full-file nur geänderte Blöcke + N Kontext-Zeilen",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/four-opencode-context-curator.js",
  "types": "dist/four-opencode-context-curator.d.ts",
  "exports": {
    ".": {
      "import": "./dist/four-opencode-context-curator.js",
      "types": "./dist/four-opencode-context-curator.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/four-opencode-context-curator.ts --outdir dist --target bun --format esm",
    "dev": "bun build src/four-opencode-context-curator.ts --outdir dist --target bun --format esm --watch",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "four-bytes",
    "context-curator"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/four-bytes/four-opencode-context-curator.git"
  },
  "opencode": {
    "type": "plugin",
    "hooks": ["experimental.chat.system.transform"]
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.10"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "typescript": "^5.7.3"
  }
}
